intro <- read_embeddings(con, provider = "miniLM", part = "Introduction")
mat   <- embedding_matrix(intro)
sim   <- pairwise_similarity(mat)
rownames(sim) <- intro$title
hc    <- hclust(as.dist(1 - sim), method = "ward.D2")
plot(hc)
close_corpus_store(con)
